---
// Home page. Hero (spec 004); specs 005–010 append the remaining sections.
import Base from '../layouts/Base.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Hero from '../components/sections/Hero.astro';
import { site } from '../data/site';
---

<Base
  title={`${site.name} — ${site.title}`}
  description={`Personal website of ${site.name}, ${site.title}.`}
>
  <div class="toggle-slot">
    <ThemeToggle />
  </div>

  <Hero />
</Base>

<style>
  .toggle-slot {
    position: absolute;
    top: var(--space-5);
    right: var(--space-5);
    z-index: 10;
  }
</style>
