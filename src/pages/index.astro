---
// Placeholder page restyled as the living demo of the design system (spec 002).
// Spec 004 replaces this with the real hero.
import Base from '../layouts/Base.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
---

<Base
  title="Kaaveh Mohamedi — Senior Android Engineer"
  description="Personal website of Kaaveh Mohamedi, Senior Android Engineer."
>
  <div class="toggle-slot">
    <ThemeToggle />
  </div>

  <section class="section hero container">
    <p class="section-label reveal">Senior Android Engineer</p>
    <h1 class="gradient-text reveal" data-reveal-delay="100">Kaaveh Mohamedi</h1>
  </section>

  <section class="section container">
    <div class="card hover-lift reveal">
      <p class="section-label">Status</p>
      <p>This site is under construction.</p>
    </div>
  </section>
</Base>

<style>
  .toggle-slot {
    position: absolute;
    top: var(--space-5);
    right: var(--space-5);
  }

  .hero {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-4);
    min-height: 100svh;
  }

  .gradient-text {
    background: var(--gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .card {
    max-width: 28rem;
    padding: var(--space-6);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    display: grid;
    gap: var(--space-2);
  }
</style>
