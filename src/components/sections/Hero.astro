---
// Hero — spec 004. Everything user-facing renders from `src/data/site.ts`;
// no resume facts live in this component. Icon paths are shared with the
// Footer (010) via `../icons` so the SVG set is defined exactly once.
import { site } from '../../data/site';
import { iconPaths } from '../icons';
---

<section id="top" class="hero">
  <div class="orb orb-violet" aria-hidden="true"></div>
  <div class="orb orb-green" aria-hidden="true"></div>
  <div class="container hero-inner">
    <h1 class="hero-name reveal">{site.name}</h1>
    <p class="hero-role reveal" data-reveal-delay="100">{site.title}</p>
    <p class="hero-location reveal" data-reveal-delay="180">{site.location}</p>
    <p class="hero-summary reveal" data-reveal-delay="260">{site.summary}</p>
    <ul class="hero-contacts reveal" data-reveal-delay="340" aria-label="Contact links">
      {
        site.contacts.map((contact) => {
          const iconPath = iconPaths[contact.label];
          const external = !contact.url.startsWith('mailto:');
          return (
            <li>
              <a
                href={contact.url}
                target={external ? '_blank' : undefined}
                rel={external ? 'noopener' : undefined}
              >
                {iconPath && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d={iconPath} />
                  </svg>
                )}
                {contact.label}
              </a>
            </li>
          );
        })
      }
    </ul>
    <div class="hero-ctas reveal" data-reveal-delay="420">
      <a class="btn btn-primary hover-lift" href={site.resumePdf} download>
        Download Resume (PDF)
      </a>
      <a class="btn btn-ghost hover-lift" href="#experience">
        View experience <span aria-hidden="true">↓</span>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: 100vh;
    min-height: 100svh;

    --orb-violet: rgb(127 82 255 / 0.24);
    --orb-green: rgb(61 220 132 / 0.16);
  }

  :global([data-theme='light']) .hero {
    --orb-violet: rgb(127 82 255 / 0.12);
    --orb-green: rgb(61 220 132 / 0.14);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    padding-block: var(--space-8);
  }

  .hero-name {
    background: var(--gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-role {
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 1.2rem + 0.9vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .hero-location {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    letter-spacing: 0.04em;
    color: var(--text-2);
  }

  .hero-summary {
    max-width: 60ch;
    color: var(--text-2);
  }

  .hero-contacts {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    padding: 0;
    margin-block-start: var(--space-2);
  }

  .hero-contacts a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    text-decoration: none;
    color: var(--text-2);
    border: 1px solid var(--border);
    border-radius: 999px;
    transition:
      color var(--transition),
      border-color var(--transition),
      transform var(--transition);
  }

  .hero-contacts a:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-block-start: var(--space-3);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-sm);
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
    text-decoration: none;
  }

  .btn-primary {
    /* Identity gradient pinned to the brand shades in both themes: the light
       theme's darker accents fail 4.5:1 with dark text, the brand shades pass
       (#000 on #7f52ff — the gradient's worst case — is 4.55:1). */
    background: linear-gradient(135deg, #7f52ff, #3ddc84);
    color: #000;
  }

  .btn-ghost {
    border: 1px solid var(--accent);
    color: var(--accent);
  }

  /* Signature flourish: ambient gradient orbs drifting behind the content.
     Transform-only animation; static under reduced motion. */
  .orb {
    position: absolute;
    aspect-ratio: 1;
    border-radius: 50%;
    pointer-events: none;
  }

  .orb-violet {
    width: min(44rem, 110vw);
    top: -18%;
    right: -12%;
    background: radial-gradient(circle, var(--orb-violet), transparent 65%);
    animation: orb-drift-a 18s ease-in-out infinite alternate;
  }

  .orb-green {
    width: min(38rem, 100vw);
    bottom: -22%;
    left: -15%;
    background: radial-gradient(circle, var(--orb-green), transparent 65%);
    animation: orb-drift-b 22s ease-in-out infinite alternate;
  }

  @keyframes orb-drift-a {
    from {
      transform: translate3d(0, 0, 0) scale(1);
    }
    to {
      transform: translate3d(-8%, 10%, 0) scale(1.12);
    }
  }

  @keyframes orb-drift-b {
    from {
      transform: translate3d(0, 0, 0) scale(1.08);
    }
    to {
      transform: translate3d(10%, -8%, 0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .orb {
      animation: none;
    }

    .hero-contacts a,
    .hero-contacts a:hover {
      transform: none;
      transition: none;
    }
  }
</style>
