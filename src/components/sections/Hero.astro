---
// Hero — spec 004. Everything user-facing renders from `src/data/site.ts`;
// no resume facts live in this component.
import { site } from '../../data/site';

// Inline SVG icon paths (24×24, fill: currentColor), keyed by contact label.
// Brand marks from Simple Icons; the envelope is Material Symbols.
const iconPaths: Record<string, string> = {
  Email:
    'M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z',
  LinkedIn:
    'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  GitHub:
    'M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12',
  Medium:
    'M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75S24 8.83 24 12z',
  YouTube:
    'M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z',
};
---

<section id="top" class="hero">
  <div class="orb orb-violet" aria-hidden="true"></div>
  <div class="orb orb-green" aria-hidden="true"></div>
  <div class="container hero-inner">
    <h1 class="hero-name reveal">{site.name}</h1>
    <p class="hero-role reveal" data-reveal-delay="100">{site.title}</p>
    <p class="hero-location reveal" data-reveal-delay="180">{site.location}</p>
    <p class="hero-summary reveal" data-reveal-delay="260">{site.summary}</p>
    <ul class="hero-contacts reveal" data-reveal-delay="340" aria-label="Contact links">
      {
        site.contacts.map((contact) => {
          const iconPath = iconPaths[contact.label];
          const external = !contact.url.startsWith('mailto:');
          return (
            <li>
              <a
                href={contact.url}
                target={external ? '_blank' : undefined}
                rel={external ? 'noopener' : undefined}
              >
                {iconPath && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d={iconPath} />
                  </svg>
                )}
                {contact.label}
              </a>
            </li>
          );
        })
      }
    </ul>
    <div class="hero-ctas reveal" data-reveal-delay="420">
      <a class="btn btn-primary hover-lift" href={site.resumePdf} download>
        Download Resume (PDF)
      </a>
      <a class="btn btn-ghost hover-lift" href="#experience">
        View experience <span aria-hidden="true">↓</span>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: 100vh;
    min-height: 100svh;

    --orb-violet: rgb(127 82 255 / 0.24);
    --orb-green: rgb(61 220 132 / 0.16);
  }

  :global([data-theme='light']) .hero {
    --orb-violet: rgb(127 82 255 / 0.12);
    --orb-green: rgb(61 220 132 / 0.14);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
    padding-block: var(--space-8);
  }

  .hero-name {
    background: var(--gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-role {
    font-family: var(--font-heading);
    font-size: clamp(1.375rem, 1.2rem + 0.9vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .hero-location {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    letter-spacing: 0.04em;
    color: var(--text-2);
  }

  .hero-summary {
    max-width: 60ch;
    color: var(--text-2);
  }

  .hero-contacts {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
    padding: 0;
    margin-block-start: var(--space-2);
  }

  .hero-contacts a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    text-decoration: none;
    color: var(--text-2);
    border: 1px solid var(--border);
    border-radius: 999px;
    transition:
      color var(--transition),
      border-color var(--transition),
      transform var(--transition);
  }

  .hero-contacts a:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-block-start: var(--space-3);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-sm);
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
    text-decoration: none;
  }

  .btn-primary {
    /* Identity gradient pinned to the brand shades in both themes: the light
       theme's darker accents fail 4.5:1 with dark text, the brand shades pass
       (#000 on #7f52ff — the gradient's worst case — is 4.55:1). */
    background: linear-gradient(135deg, #7f52ff, #3ddc84);
    color: #000;
  }

  .btn-ghost {
    border: 1px solid var(--accent);
    color: var(--accent);
  }

  /* Signature flourish: ambient gradient orbs drifting behind the content.
     Transform-only animation; static under reduced motion. */
  .orb {
    position: absolute;
    aspect-ratio: 1;
    border-radius: 50%;
    pointer-events: none;
  }

  .orb-violet {
    width: min(44rem, 110vw);
    top: -18%;
    right: -12%;
    background: radial-gradient(circle, var(--orb-violet), transparent 65%);
    animation: orb-drift-a 18s ease-in-out infinite alternate;
  }

  .orb-green {
    width: min(38rem, 100vw);
    bottom: -22%;
    left: -15%;
    background: radial-gradient(circle, var(--orb-green), transparent 65%);
    animation: orb-drift-b 22s ease-in-out infinite alternate;
  }

  @keyframes orb-drift-a {
    from {
      transform: translate3d(0, 0, 0) scale(1);
    }
    to {
      transform: translate3d(-8%, 10%, 0) scale(1.12);
    }
  }

  @keyframes orb-drift-b {
    from {
      transform: translate3d(0, 0, 0) scale(1.08);
    }
    to {
      transform: translate3d(10%, -8%, 0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .orb {
      animation: none;
    }

    .hero-contacts a,
    .hero-contacts a:hover {
      transform: none;
      transition: none;
    }
  }
</style>
