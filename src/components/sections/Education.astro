---
// Education, certificates & languages — spec 010. The quiet coda of the
// resume: three compact groups in one lighter-weight band, rendered from
// `src/data/education.ts`. No resume facts live in this component. The IEEE
// Android-teaching note renders here and only here — Writing (008)
// deliberately omits it; see education.ts's comment.
import { education, certificates, languages } from '../../data/education';
---

<section id="education" class="section education">
  <div class="container">
    <p class="section-label reveal">// education</p>
    <h2 class="education-title reveal" data-reveal-delay="80">
      Education, certificates &amp; languages
    </h2>

    <div class="education-groups">
      <section class="group reveal" data-reveal-delay="140" aria-labelledby="education-degrees">
        <h3 id="education-degrees" class="group-title">Education</h3>
        <ul class="degree-list" role="list">
          {
            education.map((entry) => (
              <li class="degree">
                <p class="degree-name">{entry.degree}</p>
                <p class="degree-meta">{entry.institution}</p>
                {entry.note && <p class="degree-note">{entry.note}</p>}
              </li>
            ))
          }
        </ul>
      </section>

      <section class="group reveal" data-reveal-delay="200" aria-labelledby="education-certs">
        <h3 id="education-certs" class="group-title">Certificates</h3>
        <ul class="cert-list" role="list">
          {
            certificates.map((cert) => (
              <li class="cert">
                {cert.url ? (
                  <a class="cert-link" href={cert.url} target="_blank" rel="noopener noreferrer">
                    <span class="cert-title">{cert.title}</span>
                    <span class="ext-icon" aria-hidden="true">
                      ↗
                    </span>
                  </a>
                ) : (
                  <span class="cert-title">{cert.title}</span>
                )}
                <span class="cert-meta">{cert.issuer}</span>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="group reveal" data-reveal-delay="260" aria-labelledby="education-languages">
        <h3 id="education-languages" class="group-title">Languages</h3>
        <ul class="language-list" role="list">
          {
            languages.map((lang) => (
              <li class="language">
                <span class="language-name">{lang.language}</span>
                <span class="language-level">— {lang.level}</span>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </div>
</section>

<style>
  .education-title {
    margin-block-start: var(--space-2);
  }

  .education-groups {
    margin-block-start: var(--space-6);
    display: grid;
    gap: var(--space-6);
    /* Quieter than Skills (006): auto-fit stacks the three groups on mobile
       and fits them side by side once there's room, no per-group cards. */
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .group-title {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* Accent group marker — echoes Skills (006) / Writing (008). */
  .group-title::before {
    content: '';
    flex: none;
    width: 10px;
    height: 10px;
    border-radius: 3px;
    background: var(--gradient);
  }

  .degree-list,
  .cert-list {
    list-style: none;
    margin: 0;
    margin-block-start: var(--space-4);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .degree-name,
  .cert-title {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.4;
  }

  .degree-meta,
  .cert-meta {
    display: block;
    margin-block-start: var(--space-1);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    color: var(--text-2);
  }

  .degree-note {
    margin-block-start: var(--space-2);
    font-size: 0.9375rem;
    color: var(--text-2);
    line-height: 1.5;
  }

  /* Linked certs get accent title + arrow-out icon; unresolved ones (no
     verified credential URL) stay plain text with no click affordance. */
  .cert-link {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    width: fit-content;
    text-decoration: none;
    transition: transform var(--transition);
  }

  .cert-link .cert-title {
    color: var(--accent);
    transition: color var(--transition);
  }

  .ext-icon {
    flex: none;
    font-size: 0.875em;
    transition: transform var(--transition);
  }

  .cert-link:hover,
  .cert-link:focus-visible {
    transform: translateX(2px);
  }

  .cert-link:hover .ext-icon,
  .cert-link:focus-visible .ext-icon {
    transform: translate(2px, -2px);
  }

  .language-list {
    list-style: none;
    margin: 0;
    margin-block-start: var(--space-4);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .language {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .language-name {
    font-size: 1rem;
    color: var(--text);
  }

  .language-level {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-2);
  }

  @media (prefers-reduced-motion: reduce) {
    .cert-link,
    .ext-icon {
      transition: none;
    }

    .cert-link:hover,
    .cert-link:focus-visible {
      transform: none;
    }

    .cert-link:hover .ext-icon,
    .cert-link:focus-visible .ext-icon {
      transform: none;
    }
  }
</style>
