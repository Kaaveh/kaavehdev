---
// Skills — spec 006. Responsive grid of skill-group cards rendered from
// `src/data/skills.ts`, in data order; no resume facts live in this component.
import { skills } from '../../data/skills';
---

<section id="skills" class="section skills">
  <div class="container">
    <p class="section-label reveal">// skills</p>
    <h2 class="skills-title reveal" data-reveal-delay="80">What I build with</h2>

    <ul class="skills-grid" role="list">
      {
        skills.map((group, index) => (
          <li class="skill-group reveal" data-reveal-delay={140 + index * 60}>
            <h3 class="skill-group-title">{group.title}</h3>
            <ul class="chips" role="list">
              {group.skills.map((skill) => (
                <li class="chip">{skill}</li>
              ))}
            </ul>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .skills-title {
    margin-block-start: var(--space-2);
  }

  .skills-grid {
    list-style: none;
    margin: 0;
    margin-block-start: var(--space-7);
    padding: 0;
    display: grid;
    gap: var(--space-5);
    /* 1 col at 320px, filling to 2 (tablet) then 3–4 (desktop) as space allows.
       auto-fit keeps rows aligned so uneven chip counts don't break rhythm. */
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .skill-group {
    padding: var(--space-5);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .skill-group-title {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--text);
  }

  /* Accent group marker — the only always-on color in the card. */
  .skill-group-title::before {
    content: '';
    flex: none;
    width: 10px;
    height: 10px;
    border-radius: 3px;
    background: var(--gradient);
  }

  .chips {
    list-style: none;
    margin: 0;
    margin-block-start: var(--space-4);
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .chip {
    padding: var(--space-1) var(--space-3);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    color: var(--text-2);
    /* Only paint transitions — border/shadow can't shift layout on hover. */
    transition:
      border-color var(--transition),
      box-shadow var(--transition),
      color var(--transition);
  }

  .chip:hover {
    border-color: var(--accent);
    box-shadow: var(--glow);
    color: var(--text);
  }

  @media (prefers-reduced-motion: reduce) {
    .chip,
    .chip:hover {
      transition: none;
    }
  }
</style>
</parameter>
</invoke>
